rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isProf() { 
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'STUDENT') == 'PROFESSOR';
    }

    match /users/{userId} {
      function isValidUser(data) {
        return data.get('name', '') is string && 
               data.get('role', '') in ['STUDENT', 'PROFESSOR'];
      }

      // Owner check first for short-circuit efficiency
      allow read: if isSignedIn() && (request.auth.uid == userId || isProf());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && 
        isValidUser(incoming()) && 
        incoming().get('role', 'STUDENT') == existing().get('role', 'STUDENT');
    }

    match /projects/{projectId} {
      function isMember() {
        return isSignedIn() && (request.auth.uid in existing().get('memberIds', []));
      }

      function isJoining() {
        return isSignedIn() && 
               incoming().diff(existing()).affectedKeys().hasAny(['students', 'memberIds', 'lastInteraction']) &&
               request.auth.uid in incoming().get('memberIds', []);
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isProf() || isMember() || isJoining());
    }
    
    match /projects/{projectId}/cards/{cardId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (
        isProf() || 
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('memberIds', [])
      );
    }
  }
}
