rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Basic Helpers
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Admin/Professor check using Email directly
    function isProf() { 
      return isSignedIn() && request.auth.token.email == 'demostenestj@gmail.com'; 
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // 2. Projects Collection
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isProf() || 
        (request.auth.uid in existing().get('memberIds', [])) ||
        (request.auth.uid in incoming().get('memberIds', []))
      );
    }

    // 3. Kanban Cards Subcollection
    match /projects/{projectId}/cards/{cardId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isProf() || 
        (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('memberIds', []))
      );
    }
  }
}
