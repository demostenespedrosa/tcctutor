rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isProf() { 
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'PROFESSOR';
    }

    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['name', 'role']) &&
          data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
          data.role in ['STUDENT', 'PROFESSOR'] &&
          (data.get('projectId', '') is string);
      }

      allow read: if isSignedIn() && (request.auth.uid == userId || isProf());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && 
        isValidUser(incoming()) && 
        incoming().role == existing().role && 
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'projectId']);
    }

    match /projects/{projectId} {
      function isValidProject(data) {
        return data.keys().hasAll(['token', 'name', 'students', 'memberIds', 'lastInteraction', 'phases']) &&
               data.token is string &&
               data.name is string &&
               data.students is list &&
               data.memberIds is list &&
               data.phases is map;
      }
      
      function isMember() {
        return isSignedIn() && (request.auth.uid in existing().memberIds);
      }

      function isJoining() {
        return isSignedIn() && 
               incoming().diff(existing()).affectedKeys().hasOnly(['students', 'memberIds', 'lastInteraction']) &&
               request.auth.uid in incoming().memberIds;
      }

      allow read: if isSignedIn(); // Allow searching and retrieval for all students/profs
      
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming()) &&
                    request.auth.uid in incoming().memberIds;

      allow update: if isSignedIn() && isValidId(projectId) && (
        isProf() || 
        isMember() ||
        isJoining()
      ) && isValidProject(incoming());
    }
    
    match /projects/{projectId}/cards/{cardId} {
      function isValidCard(data) {
        return data.keys().hasAll(['title', 'description', 'status', 'blockReason']) &&
               data.title is string && data.title.size() <= 150 &&
               data.description is string && data.description.size() <= 2000 &&
               data.status in ['BACKLOG', 'TODO', 'IN_PROGRESS', 'BLOCKED', 'DONE'] &&
               data.blockReason is string && data.blockReason.size() <= 500;
      }

      function canAccessParent() {
        return existingParent().memberIds.hasAny([request.auth.uid]) || isProf();
      }
      
      function existingParent() {
        return get(/databases/$(database)/documents/projects/$(projectId)).data;
      }

      allow read, list: if isSignedIn() && isValidId(projectId) && (
        isProf() || (
          exists(/databases/$(database)/documents/projects/$(projectId)) &&
          request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds
        )
      );

      allow create: if isSignedIn() && isValidId(projectId) && isValidId(cardId) && 
        exists(/databases/$(database)/documents/projects/$(projectId)) &&
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds &&
        isValidCard(incoming());

      allow update: if isSignedIn() && isValidId(projectId) && isValidId(cardId) && 
        exists(/databases/$(database)/documents/projects/$(projectId)) &&
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds &&
        isValidCard(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasAny(['title', 'description', 'status', 'blockReason']);
        
      allow delete: if isSignedIn() && isValidId(projectId) && isValidId(cardId) && 
        exists(/databases/$(database)/documents/projects/$(projectId)) &&
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds;
    }
  }
}
